<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_app_gradient"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:text="Inbox"
        android:textColor="@color/color_text_primary"
        android:textStyle="bold"
        android:textSize="24sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/inboxList"
        android:text="Loading inbox..."
        android:textColor="@color/color_text_body"
        android:background="@drawable/bg_card"
        android:layout_marginTop="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/acceptInviteButton"
        android:text="Accept First Invite"
        android:textColor="@color/white"
        android:background="@drawable/bg_button_primary"
        android:layout_marginTop="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/declineInviteButton"
        android:text="Decline First Invite"
        android:textColor="@color/color_text_primary"
        android:background="@drawable/bg_button_secondary"
        android:layout_marginTop="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/acceptVerificationButton"
        android:text="Accept First Verification"
        android:textColor="@color/white"
        android:background="@drawable/bg_button_primary"
        android:layout_marginTop="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/declineVerificationButton"
        android:text="Decline First Verification"
        android:textColor="@color/color_text_primary"
        android:background="@drawable/bg_button_secondary"
        android:layout_marginTop="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
</LinearLayout>
