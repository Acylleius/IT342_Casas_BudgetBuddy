{
  "info": {
    "name": "BudgetBuddy Finals User API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('request completed without server error', function () {",
          "  pm.expect(pm.response.code).to.be.below(500);",
          "});"
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "groupId", "value": "1" },
    { "key": "budgetId", "value": "1" },
    { "key": "savingGoalId", "value": "1" },
    { "key": "transactionId", "value": "1" },
    { "key": "groupTransactionId", "value": "1" },
    { "key": "selectedUserId", "value": "2" },
    { "key": "invitationId", "value": "1" },
    { "key": "inboxId", "value": "1" }
  ],
  "item": [
    {
      "name": "AUTH",
      "item": [
        { "name": "POST /auth/register", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/auth/register", "body": { "mode": "raw", "raw": "{\"email\":\"user.a@example.com\",\"password\":\"Password123!\",\"firstname\":\"User\",\"lastname\":\"A\"}" } } },
        { "name": "POST /auth/login", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/auth/login", "body": { "mode": "raw", "raw": "{\"email\":\"user.a@example.com\",\"password\":\"Password123!\"}" } } },
        { "name": "POST /auth/refresh", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/auth/refresh", "body": { "mode": "raw", "raw": "{\"refreshToken\":\"{{refreshToken}}\"}" } } },
        { "name": "POST /auth/logout", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/auth/logout" } },
        { "name": "GET /auth/me", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/auth/me" } }
      ]
    },
    {
      "name": "TRANSACTIONS",
      "item": [
        { "name": "GET /transactions", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/transactions" } },
        { "name": "POST /transactions - personal expense with category", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/transactions", "body": { "mode": "raw", "raw": "{\"type\":\"EXPENSE\",\"amount\":500,\"category\":\"GROCERIES\"}" } } },
        { "name": "PUT /transactions/{id}", "request": { "method": "PUT", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/transactions/{{transactionId}}", "body": { "mode": "raw", "raw": "{\"type\":\"EXPENSE\",\"amount\":650,\"category\":\"GROCERIES\"}" } } },
        { "name": "DELETE /transactions/{id}", "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/transactions/{{transactionId}}" } }
      ]
    },
    {
      "name": "GROUPS",
      "item": [
        { "name": "POST /groups", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/groups", "body": { "mode": "raw", "raw": "{\"name\":\"Roommates\",\"description\":\"Finals group\"}" } } },
        { "name": "GET /groups", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/groups" } },
        { "name": "GET /groups/{groupId}", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/groups/{{groupId}}" } },
        { "name": "POST /groups/{groupId}/invitations", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/groups/{{groupId}}/invitations", "body": { "mode": "raw", "raw": "{\"email\":\"user.b@example.com\"}" } } },
        { "name": "GET /groups/{groupId}/history", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/groups/{{groupId}}/history" } }
      ]
    },
    {
      "name": "INVITATIONS",
      "item": [
        { "name": "GET /invitations", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/invitations" } },
        { "name": "POST /invitations/{invitationId}/accept", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/invitations/{{invitationId}}/accept" } },
        { "name": "POST /invitations/{invitationId}/decline", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/invitations/{{invitationId}}/decline" } }
      ]
    },
    {
      "name": "GROUP TRANSACTIONS",
      "item": [
        { "name": "POST /groups/{groupId}/transactions - self approved", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/groups/{{groupId}}/transactions", "body": { "mode": "raw", "raw": "{\"type\":\"EXPENSE\",\"amount\":6000,\"category\":\"RENT\",\"actorUserId\":1}" } } },
        { "name": "POST /groups/{groupId}/transactions - another member pending verification", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/groups/{{groupId}}/transactions", "body": { "mode": "raw", "raw": "{\"type\":\"EXPENSE\",\"amount\":500,\"category\":\"GROCERIES\",\"description\":\"Shared groceries\",\"actorUserId\":{{selectedUserId}}}" } } },
        { "name": "GET /groups/{groupId}/transactions", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/groups/{{groupId}}/transactions" } },
        { "name": "PUT /groups/{groupId}/transactions/{transactionId}", "request": { "method": "PUT", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/groups/{{groupId}}/transactions/{{groupTransactionId}}", "body": { "mode": "raw", "raw": "{\"type\":\"EXPENSE\",\"amount\":6500,\"category\":\"RENT\",\"actorUserId\":1}" } } },
        { "name": "POST /groups/{groupId}/transactions/{transactionId}/verify - accept", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/groups/{{groupId}}/transactions/{{groupTransactionId}}/verify", "body": { "mode": "raw", "raw": "{\"decision\":\"ACCEPT\"}" } } },
        { "name": "POST /groups/{groupId}/transactions/{transactionId}/verify - decline", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/groups/{{groupId}}/transactions/{{groupTransactionId}}/verify", "body": { "mode": "raw", "raw": "{\"decision\":\"DECLINE\"}" } } },
        { "name": "DELETE /groups/{groupId}/transactions/{transactionId}", "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/groups/{{groupId}}/transactions/{{groupTransactionId}}" } },
        { "name": "GET /groups/{groupId}/budgets/tracking - approved transactions only", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/groups/{{groupId}}/budgets/tracking" } }
      ]
    },
    {
      "name": "PERSONAL BUDGETS",
      "item": [
        { "name": "POST /budgets - category budget", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/budgets", "body": { "mode": "raw", "raw": "{\"name\":\"Monthly Food Budget\",\"limitAmount\":5000,\"period\":\"MONTHLY\",\"category\":\"FOOD_AND_DINING\"}" } } },
        { "name": "POST /budgets - general budget counts all expenses", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/budgets", "body": { "mode": "raw", "raw": "{\"name\":\"Monthly General Budget\",\"limitAmount\":10000,\"period\":\"MONTHLY\",\"category\":\"GENERAL\"}" } } },
        { "name": "GET /budgets", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/budgets" } },
        { "name": "GET /budgets/tracking - verify matching categories", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/budgets/tracking" } },
        { "name": "PUT /budgets/{budgetId}", "request": { "method": "PUT", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/budgets/{{budgetId}}", "body": { "mode": "raw", "raw": "{\"name\":\"Updated Monthly Food Budget\",\"limitAmount\":6000,\"period\":\"MONTHLY\",\"category\":\"FOOD_AND_DINING\"}" } } },
        { "name": "DELETE /budgets/{budgetId}", "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/budgets/{{budgetId}}" } }
      ]
    },
    {
      "name": "GROUP BUDGETS",
      "item": [
        { "name": "POST /groups/{groupId}/budgets", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/groups/{{groupId}}/budgets", "body": { "mode": "raw", "raw": "{\"name\":\"Monthly Grocery Budget\",\"limitAmount\":5000,\"period\":\"MONTHLY\",\"category\":\"GROCERIES\"}" } } },
        { "name": "GET /groups/{groupId}/budgets", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/groups/{{groupId}}/budgets" } },
        { "name": "GET /groups/{groupId}/budgets/tracking", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/groups/{{groupId}}/budgets/tracking" } },
        { "name": "PUT /groups/{groupId}/budgets/{budgetId}", "request": { "method": "PUT", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/groups/{{groupId}}/budgets/{{budgetId}}", "body": { "mode": "raw", "raw": "{\"name\":\"Updated Grocery Budget\",\"limitAmount\":6500,\"period\":\"MONTHLY\",\"category\":\"GROCERIES\"}" } } },
        { "name": "DELETE /groups/{groupId}/budgets/{budgetId}", "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/groups/{{groupId}}/budgets/{{budgetId}}" } }
      ]
    },
    {
      "name": "PERSONAL SAVING GOALS",
      "item": [
        { "name": "POST /saving-goals", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/saving-goals", "body": { "mode": "raw", "raw": "{\"title\":\"Emergency Fund\",\"targetAmount\":10000,\"currentAmount\":1000}" } } },
        { "name": "GET /saving-goals", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/saving-goals" } },
        { "name": "PUT /saving-goals/{goalId}", "request": { "method": "PUT", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/saving-goals/{{savingGoalId}}", "body": { "mode": "raw", "raw": "{\"title\":\"Emergency Fund\",\"targetAmount\":10000,\"currentAmount\":10000}" } } },
        { "name": "DELETE /saving-goals/{goalId}", "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/saving-goals/{{savingGoalId}}" } }
      ]
    },
    {
      "name": "GROUP SAVING GOALS",
      "item": [
        { "name": "POST /groups/{groupId}/saving-goals", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/groups/{{groupId}}/saving-goals", "body": { "mode": "raw", "raw": "{\"title\":\"Trip Fund\",\"targetAmount\":20000,\"currentAmount\":2000}" } } },
        { "name": "GET /groups/{groupId}/saving-goals", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/groups/{{groupId}}/saving-goals" } },
        { "name": "PUT /groups/{groupId}/saving-goals/{goalId}", "request": { "method": "PUT", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/groups/{{groupId}}/saving-goals/{{savingGoalId}}", "body": { "mode": "raw", "raw": "{\"title\":\"Trip Fund\",\"targetAmount\":20000,\"currentAmount\":5000}" } } },
        { "name": "DELETE /groups/{groupId}/saving-goals/{goalId}", "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/groups/{{groupId}}/saving-goals/{{savingGoalId}}" } },
        { "name": "POST /groups/{groupId}/saving-goals/{goalId}/contribute", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/groups/{{groupId}}/saving-goals/{{savingGoalId}}/contribute", "body": { "mode": "raw", "raw": "{\"amount\":500,\"note\":\"monthly share\"}" } } }
      ]
    },
    {
      "name": "INBOX",
      "item": [
        { "name": "GET /inbox", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/inbox" } },
        { "name": "POST /inbox/{id}/read", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/inbox/{{inboxId}}/read" } },
        { "name": "POST /inbox/read-all", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/inbox/read-all" } }
      ]
    },
    {
      "name": "REALTIME",
      "item": [
        { "name": "GET /realtime/stream", "request": { "method": "GET", "url": "{{baseUrl}}/realtime/stream?token={{accessToken}}" } }
      ]
    }
  ]
}
